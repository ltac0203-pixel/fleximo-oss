#===============================================================================
#  FLEXIMO - 本番環境設定
#===============================================================================
#  ⚠️  このファイルは本番環境用の設定テンプレートです
#  ⚠️  本番サーバーの .env にコピーして使用してください
#===============================================================================

#-------------------------------------------------------------------------------
# アプリケーション基本設定
#-------------------------------------------------------------------------------
# アプリ名（表示名やキャッシュ接頭辞に利用）
APP_NAME=fleximo
# 実行環境（production, local など）
# ⚠️ ローカル開発時は local に変更してください。
#    production のままでは開発向け機能（デバッグ表示など）が無効になります。
APP_ENV=production
# 暗号化に使うアプリキー（base64）
APP_KEY=
# デバッグモード（本番は false）
APP_DEBUG=false
# アプリのベースURL
APP_URL=https://example.com
# プラットフォーム手数料率の既定値（bps, 600 = 6.00%）
PLATFORM_DEFAULT_FEE_RATE_BPS=600

# アプリの主言語（ja: 日本語 / en: English）
APP_LOCALE=ja
# 翻訳がない場合のフォールバック言語（多言語化対応のため en を推奨）
APP_FALLBACK_LOCALE=en
# Faker が使うロケール
APP_FAKER_LOCALE=en_US
# アプリのタイムゾーン（PHP の timezone_identifiers_list() の値、例: Asia/Tokyo / UTC / Europe/Berlin）
APP_TIMEZONE=Asia/Tokyo
# メンテナンスモードのドライバ（file / cache）
APP_MAINTENANCE_DRIVER=file

# bcrypt のコスト値
BCRYPT_ROUNDS=12

#-------------------------------------------------------------------------------
# ログ設定
#-------------------------------------------------------------------------------
# デフォルトのログチャンネル
LOG_CHANNEL=stack
# LOG_CHANNEL=stack のときに使うスタック
LOG_STACK=single
# 非推奨通知のログチャンネル
LOG_DEPRECATIONS_CHANNEL=null
# 最低ログレベル
LOG_LEVEL=error

#-------------------------------------------------------------------------------
# データベース設定（本番サーバー）
#-------------------------------------------------------------------------------
# DB ドライバ
DB_CONNECTION=mysql
# DB ホスト
DB_HOST=localhost
# DB ポート
DB_PORT=3306
# DB 名
DB_DATABASE=xxxxxxxx_xxxxx
# DB ユーザー名
DB_USERNAME=xxxxxxxxxxx
# DB パスワード
DB_PASSWORD=xxxxxxxx

# DB SSL/TLS設定（リモートDB接続時に必要に応じて有効化）
# CA証明書のファイルパス
# MYSQL_ATTR_SSL_CA=
# クライアント証明書のファイルパス
# DB_SSL_CERT=
# クライアント秘密鍵のファイルパス
# DB_SSL_KEY=
# サーバー証明書を検証するか（CA設定時デフォルトtrue）
# DB_SSL_VERIFY_SERVER_CERT=true

#-------------------------------------------------------------------------------
# セッション設定
#-------------------------------------------------------------------------------
# セッションドライバ
# ⚠ 本番環境では必ず SESSION_DRIVER=database に変更すること
# file ドライバは共有ホスティング環境でセッションハイジャックのリスクがある
SESSION_DRIVER=database
# セッション有効期限（分）
SESSION_LIFETIME=120
# セッション内容を暗号化するか
SESSION_ENCRYPT=true
# セッションクッキーのパス
SESSION_PATH=/
# セッションクッキーのドメイン（null で現ホスト）
SESSION_DOMAIN=null
# HTTPS のみセッションCookieを送る
SESSION_SECURE_COOKIE=true

#-------------------------------------------------------------------------------
# キャッシュ・キュー・ストレージ
#-------------------------------------------------------------------------------
# ブロードキャストのドライバ
BROADCAST_CONNECTION=log
# デフォルトのストレージディスク
FILESYSTEM_DISK=local
# キュー接続（sync / database など）
QUEUE_CONNECTION=database
# database キューでジョブを再配信対象に戻すまでの秒数（job timeout より長くする）
DB_QUEUE_RETRY_AFTER=120
# キャッシュストア
CACHE_STORE=database
# Memcached ホスト（memcached 利用時）
MEMCACHED_HOST=127.0.0.1

#-------------------------------------------------------------------------------
# メール設定（本番: Xserver SMTP）
#-------------------------------------------------------------------------------
# メール送信ドライバ
MAIL_MAILER=smtp
# メール送信スキーム（smtp / smtps）
MAIL_SCHEME=smtp
# SMTP ホスト
MAIL_HOST=your-email@example.com
# SMTP ポート
MAIL_PORT=587
# SMTP ユーザー名
MAIL_USERNAME=your-email@example.com
# SMTP パスワード
MAIL_PASSWORD=xxxxxx-xxxxxx
# 既定の From アドレス
MAIL_FROM_ADDRESS=your-email@example.com
# 既定の From 名称
MAIL_FROM_NAME="${APP_NAME}"
# 認証メール用の From アドレス
MAIL_FROM_ADDRESS_NO_REPLY=your-email@example.com
# 認証メール用の From 名称
MAIL_FROM_NAME_NO_REPLY="${APP_NAME}"
# お問い合わせ用の From アドレス
MAIL_FROM_ADDRESS_CONTACT=contact@example.com
# お問い合わせ用の From 名称
MAIL_FROM_NAME_CONTACT="${APP_NAME} Support"
# 管理者通知先メールアドレス
MAIL_ADMIN_ADDRESS=your-email@example.com

#-------------------------------------------------------------------------------
# Sentry エラー監視
#-------------------------------------------------------------------------------
# Laravel 側 DSN（本番 DSN はシークレット管理を参照）
SENTRY_LARAVEL_DSN=
# フロントエンド（Vite）側 DSN
VITE_SENTRY_DSN=
# 環境名（未設定時は APP_ENV を使用）
SENTRY_ENVIRONMENT=
# リリースバージョン（任意）
SENTRY_RELEASE=
# トレースサンプルレート（0.0〜1.0、本番は 0.2 推奨）
SENTRY_TRACES_SAMPLE_RATE=0.2

#-------------------------------------------------------------------------------
# フロントエンド（Vite）
#-------------------------------------------------------------------------------
# Vite 側で使うアプリ名
VITE_APP_NAME="${APP_NAME}"
# KDS ポーリング間隔（ミリ秒）
VITE_KDS_POLLING_INTERVAL_MS=3000
# KDS バックオフの最大値（ミリ秒）
VITE_KDS_POLLING_BACKOFF_MAX_MS=60000
# タブが非表示のときにポーリングを止める
VITE_KDS_POLLING_PAUSE_WHEN_HIDDEN=true

#-------------------------------------------------------------------------------
# fincode 決済（テスト環境 - 本番移行時は FINCODE_PRODUCTION=true に変更）
#-------------------------------------------------------------------------------
# fincode 本番環境フラグ（true: 本番, false: テスト環境）
FINCODE_PRODUCTION=false
# fincode APIキー（シークレットキー）
FINCODE_API_KEY=m_test_xxxxxxxxxx
# fincode ショップID
FINCODE_SHOP_ID=s_xxxxxxxx
# fincode Webhook検証用シークレット
FINCODE_WEBHOOK_SECRET=xxxxxxxx
# fincode パブリックキー（フロントエンド用）
VITE_FINCODE_PUBLIC_KEY=p_test_xxxxxxxxxx

#-------------------------------------------------------------------------------
# OSS版テンプレート用の運営者情報（特定商取引法・プライバシーポリシー表記）
#-------------------------------------------------------------------------------
# ⚠️ OSS版を SaaS として提供する場合は、必ず自社情報に書き換えてください。
# Legal ページ（/legal/transactions, /legal/privacy-policy など）に表示されます。
COMPANY_NAME="Your Company Name"
COMPANY_REPRESENTATIVE="Your Representative Name"
COMPANY_POSTAL_CODE="000-0000"
COMPANY_ADDRESS="Your Company Address"
COMPANY_ADDRESS_EXTRA=""
COMPANY_CONTACT_EMAIL=contact@example.com
COMPANY_BUSINESS_HOURS="Weekdays 10:00-18:00"
COMPANY_WEBSITE_URL=https://example.com/

#-------------------------------------------------------------------------------
# サイト共通 SEO 設定
#-------------------------------------------------------------------------------
# OG画像のパス（APP_URL からの相対パス）
SEO_DEFAULT_IMAGE_PATH=/og-image.svg
# ロゴ画像のパス
SEO_LOGO_PATH=/logo.png
# 構造化データに使う窓口メールアドレス
SEO_CONTACT_EMAIL=contact@example.com
SEO_SUPPORT_EMAIL=support@example.com
