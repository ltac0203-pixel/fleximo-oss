{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "fleximo",
    "license": "Apache-2.0",
    "type": "module",
    "scripts": {
        "build": "tsc && vite build --mode production",
        "dev": "vite",
        "lint": "eslint \"resources/js/**/*.{ts,tsx,js,jsx}\"",
        "format": "prettier --write \"resources/**/*.{ts,tsx,js,jsx,css,scss,json,md,mdx,html,yml,yaml}\" \"*.{js,cjs,mjs,json,md,mdx,yml,yaml}\"",
        "format:check": "prettier --check \"resources/**/*.{ts,tsx,js,jsx,css,scss,json,md,mdx,html,yml,yaml}\" \"*.{js,cjs,mjs,json,md,mdx,yml,yaml}\"",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest --coverage",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:report": "playwright show-report"
    },
    "devDependencies": {
        "@headlessui/react": "^2.2.10",
        "@inertiajs/react": "^2.3.21",
        "@playwright/test": "^1.59.1",
        "@rollup/rollup-win32-x64-msvc": "^4.60.1",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.2.2",
        "@testing-library/jest-dom": "^6.1.5",
        "@testing-library/react": "^16.0.0",
        "@testing-library/user-event": "^14.5.1",
        "@types/node": "^22.19.17",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.0.0",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "@vitejs/plugin-react": "^4.2.0",
        "@vitest/coverage-v8": "^4.1.4",
        "@vitest/ui": "^4.0.18",
        "autoprefixer": "^10.5.0",
        "concurrently": "^9.0.1",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.34.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "jsdom": "^25.0.0",
        "laravel-vite-plugin": "^2.1.0",
        "postcss": "^8.5.10",
        "prettier": "^3.8.3",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "rollup": "^4.60.1",
        "tailwindcss": "^3.2.1",
        "typescript": "^5.0.2",
        "vite": "^7.3.2",
        "vitest": "^4.0.18"
    },
    "optionalDependencies": {
        "@rollup/rollup-win32-x64-msvc": "^4.60.1"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@sentry/react": "^10.49.0",
        "@sentry/vite-plugin": "^5.2.0",
        "@tanstack/react-virtual": "^3.13.24",
        "recharts": "^3.8.1",
        "zustand": "^5.0.12"
    }
}
